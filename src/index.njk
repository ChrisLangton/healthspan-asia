<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Healthspan.Asia | Longevity Concierge for Adults 50+</title>
  <meta name="description" content="Healthspan.Asia is Asia's longevity concierge for adults over 50. Personal coaching, nutrition, physiotherapy, doctor referrals, and whole-person health support, quietly coordinated and deeply personalised." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="style.css" />
  <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
</head>
<body>

<!-- ===== SVG ICON SPRITE ===== -->
<svg xmlns="http://www.w3.org/2000/svg" style="display:none" aria-hidden="true">

  <!-- Leaf / nature / nutrition / lifestyle -->
  <symbol id="i-leaf" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z"/>
    <path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/>
  </symbol>

  <!-- Sprout / growth / mission -->
  <symbol id="i-sprout" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <path d="M12 22V12"/>
    <path d="M12 12C12 12 7 8.5 7 5.5A5 5 0 0 1 17 5.5C17 8.5 12 12 12 12z"/>
    <path d="M12 12c-2-2-5-2-7-.5"/>
  </symbol>

  <!-- Zap / energy / lightning -->
  <symbol id="i-zap" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
  </symbol>

  <!-- Moon / sleep -->
  <symbol id="i-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
  </symbol>

  <!-- Target / body composition / weight goal -->
  <symbol id="i-target" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="12" cy="12" r="10"/>
    <circle cx="12" cy="12" r="6"/>
    <circle cx="12" cy="12" r="2"/>
  </symbol>

  <!-- Plus in circle / injury / medical -->
  <symbol id="i-plus-circle" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="12" cy="12" r="10"/>
    <line x1="12" y1="8" x2="12" y2="16"/>
    <line x1="8" y1="12" x2="16" y2="12"/>
  </symbol>

  <!-- DNA / genetics -->
  <symbol id="i-dna" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <path d="M2 6c4-4 8 4 12 0s6-4 8 0"/>
    <path d="M2 12c4-4 8 4 12 0s6-4 8 0"/>
    <path d="M2 18c4-4 8 4 12 0s6-4 8 0"/>
    <line x1="2" y1="6" x2="2" y2="18"/>
    <line x1="22" y1="6" x2="22" y2="18"/>
  </symbol>

  <!-- Hourglass / age -->
  <symbol id="i-hourglass" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <path d="M5 3h14"/>
    <path d="M5 21h14"/>
    <path d="M5 3l7 9 7-9"/>
    <path d="M5 21l7-9 7 9"/>
  </symbol>

  <!-- Person / sex / body -->
  <symbol id="i-person" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="12" cy="7" r="4"/>
    <path d="M5.5 22v-2a6.5 6.5 0 0 1 13 0v2"/>
  </symbol>

  <!-- Flame / oxidation / metabolism -->
  <symbol id="i-flame" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <path d="M12 2c0 5-5 7-5 12a5 5 0 0 0 10 0C17 9 12 7 12 2z"/>
    <path d="M12 8c0 3-2 4.5-2 6.5a2 2 0 0 0 4 0C14 12.5 12 11 12 8z"/>
  </symbol>

  <!-- Activity / exercise / EKG wave -->
  <symbol id="i-activity" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
  </symbol>

  <!-- Brain / mind / mental health -->
  <symbol id="i-brain" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96-.44 2.5 2.5 0 0 1-2.96-3.08 3 3 0 0 1-.34-5.58 2.5 2.5 0 0 1 1.32-4.24 2.5 2.5 0 0 1 1.98-3A2.5 2.5 0 0 1 9.5 2z"/>
    <path d="M14.5 2A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.96-.44 2.5 2.5 0 0 0 2.96-3.08 3 3 0 0 0 .34-5.58 2.5 2.5 0 0 0-1.32-4.24 2.5 2.5 0 0 0-1.98-3A2.5 2.5 0 0 0 14.5 2z"/>
  </symbol>

  <!-- Sun / lifestyle / spiritual -->
  <symbol id="i-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="12" cy="12" r="4"/>
    <line x1="12" y1="2" x2="12" y2="5"/>
    <line x1="12" y1="19" x2="12" y2="22"/>
    <line x1="4.93" y1="4.93" x2="7.05" y2="7.05"/>
    <line x1="16.95" y1="16.95" x2="19.07" y2="19.07"/>
    <line x1="2" y1="12" x2="5" y2="12"/>
    <line x1="19" y1="12" x2="22" y2="12"/>
    <line x1="4.93" y1="19.07" x2="7.05" y2="16.95"/>
    <line x1="16.95" y1="7.05" x2="19.07" y2="4.93"/>
  </symbol>

  <!-- Stethoscope / medical coordination -->
  <symbol id="i-stethoscope" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="17" cy="18" r="3"/>
    <path d="M17 15v-2a5 5 0 0 0-10 0v4a4 4 0 0 0 4 4h3"/>
    <line x1="14" y1="18" x2="17" y2="18"/>
  </symbol>

  <!-- Dumbbell / strength -->
  <symbol id="i-dumbbell" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <rect x="2" y="10" width="4" height="5" rx="1"/>
    <rect x="18" y="10" width="4" height="5" rx="1"/>
    <line x1="6" y1="12.5" x2="18" y2="12.5"/>
    <line x1="2" y1="11.5" x2="2" y2="13.5" stroke-width="2.5"/>
    <line x1="22" y1="11.5" x2="22" y2="13.5" stroke-width="2.5"/>
  </symbol>

  <!-- Person stretching / mobility -->
  <symbol id="i-stretch" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="12" cy="4" r="2"/>
    <line x1="12" y1="6" x2="12" y2="16"/>
    <line x1="5" y1="9" x2="19" y2="9"/>
    <path d="M8 20l4-4 4 4"/>
  </symbol>

  <!-- Heart / sexuality / love -->
  <symbol id="i-heart" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
  </symbol>

  <!-- Flask / science -->
  <symbol id="i-flask" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <path d="M9 3h6M9 3v5.5L5 15c-1 2-.2 4.5 2 5.5 1 .5 2 .5 5 .5s4 0 5-.5c2.2-1 3-3.5 2-5.5L15 8.5V3"/>
    <circle cx="11" cy="16" r="1" fill="currentColor" stroke="none"/>
    <circle cx="14" cy="14" r="0.8" fill="currentColor" stroke="none"/>
  </symbol>

  <!-- Pencil / art -->
  <symbol id="i-pencil" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z"/>
  </symbol>

  <!-- Trending up / progress -->
  <symbol id="i-trending" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/>
    <polyline points="17 6 23 6 23 12"/>
  </symbol>

  <!-- Book open / glossary -->
  <symbol id="i-book" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
    <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
  </symbol>

  <!-- Bar chart / biomarkers -->
  <symbol id="i-bar-chart" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
    <line x1="18" y1="20" x2="18" y2="10"/>
    <line x1="12" y1="20" x2="12" y2="4"/>
    <line x1="6" y1="20" x2="6" y2="14"/>
    <line x1="2" y1="20" x2="22" y2="20"/>
  </symbol>

</svg>
<!-- ===== END ICON SPRITE ===== -->

  <!-- NAV -->
  <header class="nav-wrap" id="nav">
    <div class="container nav-inner">
      <a href="#" class="logo">
        <img src="logo.png?v=2" alt="Healthspan Concierge — Live Better. For Longer." class="logo-img" style="height:48px!important;max-height:48px!important;width:auto!important;margin-left:36px;" />
      </a>
      <nav class="nav-links">
        <a href="#what-is-healthspan">What is Healthspan?</a>
        <a href="#services">Our Approach</a>
        <a href="#how-we-work">How We Work</a>
        <a href="#about">About</a>
        <a href="#testimonials">Stories</a>
      </nav>
      <a href="#consult" class="btn btn-nav">Begin Your Journey</a>
      <button class="hamburger" id="hamburger" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
    </div>
    <div class="mobile-menu" id="mobileMenu">
      <a href="#what-is-healthspan" onclick="closeMobile()">What is Healthspan?</a>
      <a href="#services" onclick="closeMobile()">Our Approach</a>
      <a href="#how-we-work" onclick="closeMobile()">How We Work</a>
      <a href="#about" onclick="closeMobile()">About</a>
      <a href="#testimonials" onclick="closeMobile()">Stories</a>
      <a href="#consult" class="btn btn-primary" onclick="closeMobile()">Begin Your Journey</a>
    </div>
  </header>

  <!-- HERO -->
  <section class="hero" id="home">
    <canvas id="heroCanvas" aria-hidden="true"></canvas>
    <div class="hero-bg"></div>
    <div class="hero-organic-shape"></div>
    <div class="container hero-inner">
      <div class="hero-badge">{{ hero.badge }}</div>
      <h1 class="hero-headline">Live Better<span class="hero-dot">.</span><br />For Longer<span class="hero-dot">.</span></h1>
      <p class="hero-sub">We work with you and our specialist partners to maximise your Healthspan by bringing together the right knowledge, the right people, and the right support so you can live more fully, for more years.</p>
      <div class="hero-cta-group">
        <a href="#consult" class="btn btn-primary btn-lg">Begin Your Journey</a>
        <a href="#what-is-healthspan" class="btn btn-ghost btn-lg">What is Healthspan?</a>
      </div>
      <div class="hero-trust">
        <div class="trust-item"><span class="trust-num">{{ hero.stat1_num }}</span><span class="trust-label">{{ hero.stat1_label }}</span></div>
        <div class="trust-divider"></div>
        <div class="trust-item"><span class="trust-num">{{ hero.stat2_num }}</span><span class="trust-label">{{ hero.stat2_label }}</span></div>
        <div class="trust-divider"></div>
        <div class="trust-item"><span class="trust-num">{{ hero.stat3_num }}</span><span class="trust-label">{{ hero.stat3_label }}</span></div>
      </div>
    </div>
    <div class="hero-scroll-hint">
      <span>Scroll to explore</span>
      <div class="scroll-line"></div>
    </div>
  </section>

  <!-- PROBLEM / EMPATHY -->
  <section class="empathy">
    <div class="container empathy-inner">
      <div class="empathy-text">
        <h2>{{ empathy.heading }}</h2>
        <p>{{ empathy.paragraph1 }}</p>
        <p>{{ empathy.paragraph2 }}</p>
      </div>
      <div class="empathy-cards">
        {% set pain_icons = ["#i-zap","#i-target","#i-plus-circle","#i-moon"] %}
        {% for card in empathy.pain_cards %}
        <div class="pain-card">
          <div class="pain-icon"><svg class="ico" aria-hidden="true"><use href="{{ pain_icons[loop.index0] }}"/></svg></div>
          <p>{{ card }}</p>
        </div>
        {% endfor %}
      </div>
    </div>
  </section>

  <!-- WHAT IS HEALTHSPAN -->
  <section class="what-is-healthspan" id="what-is-healthspan">
    <div class="nature-divider nature-divider-top"></div>
    <div class="container">
      <div class="healthspan-split">
        <div class="healthspan-visual">
          <div class="hs-linechart">
            <svg viewBox="0 0 660 400" xmlns="http://www.w3.org/2000/svg" class="hs-svg" role="img" aria-label="Chart: Successful Ageing — Healthspan versus Lifespan, adapted from Peter Attia's Outlive">

              <defs>
                <marker id="arrowRed" markerWidth="8" markerHeight="8" refX="7" refY="3" orient="auto">
                  <path d="M0,0 L0,6 L8,3 z" fill="#cc2200"/>
                </marker>
                <marker id="arrowGreen" markerWidth="8" markerHeight="8" refX="7" refY="3" orient="auto">
                  <path d="M0,0 L0,6 L8,3 z" fill="#00a878"/>
                </marker>
              </defs>

              <!-- Title -->
              <text x="330" y="26" text-anchor="middle" fill="#111" font-size="14" font-family="Poppins, sans-serif" font-weight="700">Successful Ageing — Healthspan versus Lifespan</text>

              <!-- Y-axis -->
              <line x1="90" y1="318" x2="90" y2="48" stroke="#111" stroke-width="2.5" stroke-linecap="round"/>
              <polygon points="90,42 85,55 95,55" fill="#111"/>

              <!-- X-axis -->
              <line x1="90" y1="318" x2="628" y2="318" stroke="#111" stroke-width="2.5" stroke-linecap="round"/>
              <polygon points="634,318 621,313 621,323" fill="#111"/>

              <!-- Y-axis label -->
              <text x="28" y="185" text-anchor="middle" fill="#111" font-size="14" font-family="Poppins, sans-serif" font-weight="700" transform="rotate(-90 28 185)">Health</text>

              <!-- X-axis label -->
              <text x="355" y="352" text-anchor="middle" fill="#111" font-size="14" font-family="Poppins, sans-serif" font-weight="700">Years of life</text>

              <!-- RED curve: starts at same point as green, immediately declines -->
              <path d="M 100,87 C 290,87 513,210 513,316"
                    fill="none" stroke="#cc2200" stroke-width="3" stroke-linecap="round"/>

              <!-- GREEN curve: starts at same point, flat then quadratic cliff -->
              <path d="M 100,87 L 470,87 Q 608,87 608,316"
                    fill="none" stroke="#00a878" stroke-width="3" stroke-linecap="round"/>

              <!-- "Lifespan Ageing" label -->
              <text x="258" y="205" fill="#cc2200" font-size="12.5" font-family="Poppins, sans-serif" font-weight="600">Lifespan</text>
              <text x="258" y="221" fill="#cc2200" font-size="12.5" font-family="Poppins, sans-serif" font-weight="600">Ageing</text>
              <line x1="318" y1="213" x2="352" y2="185" stroke="#cc2200" stroke-width="1.8" marker-end="url(#arrowRed)"/>

              <!-- "Healthspan Ageing" label -->
              <text x="475" y="205" fill="#00a878" font-size="12.5" font-family="Poppins, sans-serif" font-weight="600">Healthspan</text>
              <text x="475" y="221" fill="#00a878" font-size="12.5" font-family="Poppins, sans-serif" font-weight="600">Ageing</text>
              <line x1="550" y1="213" x2="584" y2="185" stroke="#00a878" stroke-width="1.8" marker-end="url(#arrowGreen)"/>

            </svg>
            <p class="hs-chart-note">{{ healthspan_section.chart_note }}</p>
          </div>
        </div>
        <div class="healthspan-text">
          <div class="section-tag">{{ healthspan_section.section_tag }}</div>
          <h2>{{ healthspan_section.heading }}</h2>
          <p class="healthspan-lead">{{ healthspan_section.lead }}</p>
          <p><strong>Healthspan</strong> {{ healthspan_section.paragraph1 }}</p>
          <p>{{ healthspan_section.paragraph2 }}</p>
          <p>{{ healthspan_section.paragraph3 }}</p>
          <a href="#what-affects" class="btn btn-secondary">{{ healthspan_section.cta_text }}</a>
        </div>
      </div>
    </div>
    <div class="nature-divider nature-divider-bottom"></div>
  </section>

  <!-- WHAT AFFECTS YOUR HEALTHSPAN -->
  <section class="what-affects" id="what-affects">
    <div class="container">
      <div class="section-header">
        <div class="section-tag">{{ what_affects.section_tag }}</div>
        <h2>{{ what_affects.heading }}</h2>
        <p class="section-sub">{{ what_affects.subtext }}</p>
      </div>
      {% set affects_icons = ["#i-dna","#i-hourglass","#i-person","#i-flame","#i-moon","#i-leaf","#i-activity","#i-brain","#i-sun","#i-stethoscope"] %}
      <div class="affects-grid">
        {% for card in what_affects.cards %}
        <div class="affect-card">
          <div class="affect-icon"><svg class="ico" aria-hidden="true"><use href="{{ affects_icons[loop.index0] }}"/></svg></div>
          <h3>{{ card.title }}</h3>
          <p>{{ card.body }}</p>
        </div>
        {% endfor %}
      </div>
    </div>
  </section>

  <!-- FOUNDATIONAL PILLARS -->
  <section class="pillars" id="pillars">
    <div class="container">
      <div class="section-header">
        <div class="section-tag">{{ pillars.section_tag }}</div>
        <h2>{{ pillars.heading }}</h2>
        <p class="section-sub">{{ pillars.subtext }}</p>
      </div>
      {% set pillar_icons = ["#i-leaf","#i-moon","#i-stretch","#i-brain","#i-sun","#i-zap","#i-stethoscope"] %}
      <div class="pillars-row">
        {% for pillar in pillars.pillars %}
        <div class="pillar-card">
          <div class="pillar-icon"><svg class="ico" aria-hidden="true"><use href="{{ pillar_icons[loop.index0] }}"/></svg></div>
          <h3>{{ pillar.title }}</h3>
          <p>{{ pillar.body }}</p>
        </div>
        {% endfor %}
      </div>
    </div>
  </section>

  <!-- YOUR OBJECTIVES -->
  <section class="objectives" id="objectives">
    <div class="container">
      <div class="section-header">
        <div class="section-tag">{{ objectives.section_tag }}</div>
        <h2>{{ objectives.heading }}</h2>
        <p class="section-sub">{{ objectives.subtext }}</p>
      </div>

      {% set obj_icons = ["#i-zap","#i-target","#i-dumbbell","#i-heart","#i-stretch","#i-moon","#i-bar-chart","#i-brain","#i-plus-circle"] %}
      <div class="objectives-grid" id="objectivesGrid">
        {% for card in objectives.cards %}
        <button class="objective-card" onclick="selectObjective(this)">
          <div class="obj-icon"><svg class="ico" aria-hidden="true"><use href="{{ obj_icons[loop.index0] }}"/></svg></div>
          <h4>{{ card }}</h4>
        </button>
        {% endfor %}
      </div>

      <div class="objectives-footer">
        <div class="objectives-cta" id="objectivesCta" style="display:none;">
          <p>{{ objectives.selected_cta }}</p>
          <a href="#consult" class="btn btn-primary">Let's begin →</a>
        </div>
        <div class="objectives-unsure">
          <p>{{ objectives.unsure_text }}</p>
          <a href="#" class="btn btn-outline">Take the questionnaire →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- WHAT DOES HEALTHSPAN.ASIA DO — SERVICES -->
  <section class="services" id="services">
    <div class="container">
      <div class="section-header">
        <div class="section-tag">{{ services.section_tag }}</div>
        <h2>{{ services.heading }}</h2>
        <p class="section-sub">{{ services.subtext }}</p>
      </div>

      {% set dim_icons = ["#i-activity","#i-brain","#i-sun"] %}
      <div class="dimensions-row">
        {% for dim in services.dimensions %}
        <div class="dimension-card">
          <div class="dim-icon"><svg class="ico" aria-hidden="true"><use href="{{ dim_icons[loop.index0] }}"/></svg></div>
          <h3>{{ dim.title }}</h3>
          <p>{{ dim.body }}</p>
        </div>
        {% endfor %}
      </div>

      <div class="services-divider">
        <span>{{ services.divider_text }}</span>
      </div>

      {% set svc_icons = ["#i-dumbbell","#i-leaf","#i-moon","#i-stretch","#i-heart","#i-brain","#i-plus-circle","#i-stethoscope"] %}
      <div class="services-carousel-outer">
        <div class="services-carousel-wrap" id="servicesWrap">
          <div class="services-grid-track" id="servicesTrack">

            {% for svc in services.services %}
            <div class="service-card">
              <div class="service-icon"><svg class="ico" aria-hidden="true"><use href="{{ svc_icons[loop.index0] }}"/></svg></div>
              <h3>{{ svc.title }}</h3>
              <p>{{ svc.body }}</p>
            </div>
            {% endfor %}

          </div>
        </div>

        <div class="services-carousel-nav">
          <button class="svc-btn" id="svcPrev" aria-label="Previous service">&#8592;</button>
          <div class="svc-progress-track">
            <div class="svc-progress-fill" id="svcProgressFill"></div>
          </div>
          <button class="svc-btn" id="svcNext" aria-label="Next service">&#8594;</button>
          <span class="svc-counter" id="svcCounter">1 – 3 of 8</span>
        </div>
      </div>
    </div>
  </section>

  <!-- HOW WE WORK TOGETHER -->
  <section class="how-we-work" id="how-we-work">
    <div class="nature-wave-top"></div>
    <div class="container">
      <div class="section-header">
        <div class="section-tag">{{ how_we_work.section_tag }}</div>
        <h2>{{ how_we_work.heading }}</h2>
        <p class="section-sub">{{ how_we_work.subtext }}</p>
      </div>

      <div class="how-grid">
        {% for step in how_we_work.steps %}
        <div class="how-card">
          <div class="how-num">{{ step.num }}</div>
          <h3>{{ step.title }}</h3>
          <p>{{ step.body }}</p>
        </div>
        {% endfor %}
        <div class="how-card how-card-quote">
          <div class="how-quote-mark">"</div>
          <p class="how-quote-text">{{ how_we_work.quote }}</p>
          <span class="how-quote-attr">{{ how_we_work.quote_attr }}</span>
        </div>
      </div>
    </div>
    <div class="nature-wave-bottom"></div>
  </section>

  <!-- PERSONALISATION FOR YOU -->
  <section class="personalisation" id="personalisation">
    <div class="container">
      <div class="section-header">
        <div class="section-tag">{{ personalisation.section_tag }}</div>
        <h2>{{ personalisation.heading }}</h2>
        <p class="section-sub">{{ personalisation.subtext }}</p>
      </div>

      {% set personal_icons = ["#i-flask","#i-pencil","#i-trending"] %}
      <div class="personal-cards">
        {% for card in personalisation.cards %}
        <div class="personal-card{% if loop.index == 2 %} personal-card-featured{% endif %}">
          <div class="personal-icon"><svg class="ico" aria-hidden="true"><use href="{{ personal_icons[loop.index0] }}"/></svg></div>
          <h3>{{ card.title }}</h3>
          <p>{{ card.paragraph1 }}</p>
          <p>{{ card.paragraph2 }}</p>
          <ul class="personal-list">
            {% for item in card.list_items %}
            <li>{{ item }}</li>
            {% endfor %}
          </ul>
        </div>
        {% endfor %}
      </div>
    </div>
  </section>

  <!-- ABOUT / MISSION -->
  <section class="about" id="about">
    <div class="container about-inner">
      <div class="about-image">
        <div class="about-img-placeholder">
          <div class="about-img-leaves">
            <div class="leaf leaf-1"></div>
            <div class="leaf leaf-2"></div>
            <div class="leaf leaf-3"></div>
          </div>
          <div class="about-img-content">
            <div class="about-img-icon">
              <svg class="ico" aria-hidden="true"><use href="#i-sprout"/></svg>
            </div>
            <p>Our mission</p>
          </div>
        </div>
        <div class="about-stat-card">
          <span class="about-stat-num">{{ about.stat_num }}</span>
          <span class="about-stat-label">{{ about.stat_label }}</span>
        </div>
      </div>
      <div class="about-text">
        <div class="section-tag">{{ about.section_tag }}</div>
        <h2>{{ about.heading }}</h2>
        <p>{{ about.paragraph1 }}</p>
        <p>{{ about.paragraph2 | safe }}</p>
        <p>{{ about.paragraph3 }}</p>
        <div class="about-values">
          {% for value in about.values %}
          <div class="value-item"><span class="value-check">✓</span> {{ value }}</div>
          {% endfor %}
        </div>
        <a href="#consult" class="btn btn-primary">{{ about.cta_text }}</a>
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="testimonials" id="testimonials">
    <div class="container">
      <div class="section-header">
        <div class="section-tag">Member Stories</div>
        <h2>In Their Own Words</h2>
        <p class="section-sub">These are real people, with real lives, real challenges, and real results. We share their stories with their permission and gratitude.</p>
      </div>

      <div class="testimonial-slider" id="testimonialSlider">
        <div class="testimonial-track" id="testimonialTrack">

          {% for slide in testimonials.slides %}
          <div class="testimonial-slide">
            <div class="testimonials-grid">
              {% for card in slide.cards %}
              <div class="testimonial-card{% if card.featured %} featured{% endif %}">
                <div class="testimonial-quote">"</div>
                <p class="testimonial-text">{{ card.quote }}</p>
                <div class="testimonial-author">
                  <div class="author-avatar">{{ card.initials }}</div>
                  <div class="author-info">
                    <strong>{{ card.name }}</strong>
                    <span>{{ card.role }}</span>
                  </div>
                  <div class="testimonial-stars">★★★★★</div>
                </div>
              </div>
              {% endfor %}
            </div>
          </div>
          {% endfor %}

        </div>
      </div>

      <div class="testimonial-pagination">
        <button class="page-btn page-prev" id="pagePrev" aria-label="Previous">&#8592;</button>
        <div class="page-dots" id="pageDots">
          <button class="dot active" data-index="0"></button>
          <button class="dot" data-index="1"></button>
          <button class="dot" data-index="2"></button>
        </div>
        <button class="page-btn page-next" id="pageNext" aria-label="Next">&#8594;</button>
      </div>
      <div class="testimonial-counter" id="testimonialCounter">1 / 3</div>
    </div>
  </section>

  <!-- DEMYSTIFICATION GLOSSARY -->
  <section class="glossary" id="glossary">
    <div class="container">
      <div class="section-header">
        <div class="section-tag">{{ glossary.section_tag }}</div>
        <h2>{{ glossary.heading }}</h2>
        <p class="section-sub">{{ glossary.subtext }}</p>
      </div>
      <div class="glossary-note">
        <span class="glossary-note-icon">
          <svg class="ico" aria-hidden="true"><use href="#i-book"/></svg>
        </span>
        <p>{{ glossary.note }}</p>
      </div>
      <div class="glossary-list" id="glossaryList">
        {% for item in glossary.items %}
        <div class="glossary-item">
          <button class="glossary-term" onclick="toggleGlossary(this)">
            {{ item.term }}
            <span class="glossary-arrow">▼</span>
          </button>
          <div class="glossary-def">
            <p>{{ item.definition }}</p>
          </div>
        </div>
        {% endfor %}
      </div>
    </div>
  </section>

  <!-- SOCIAL PROOF BAR -->
  <section class="proof-bar">
    <div class="container proof-inner">
      {% for item in proof.stats %}
      <div class="proof-item">
        <span class="proof-num">{{ item.num }}</span>
        <span class="proof-text">{{ item.text }}</span>
      </div>
      {% endfor %}
    </div>
  </section>

  <!-- CTA SECTION -->
  <section class="cta-section" id="consult">
    <div class="cta-nature-left"></div>
    <div class="cta-nature-right"></div>
    <div class="container cta-inner">
      <div class="cta-badge">{{ cta.badge }}</div>
      <h2>{{ cta.heading }}</h2>
      <p>{{ cta.subtext }}</p>
      <form class="cta-form" id="ctaForm" onsubmit="handleFormSubmit(event)">
        <div class="form-row">
          <input type="text" placeholder="Your Name" required class="form-input" />
          <input type="email" placeholder="Email Address" required class="form-input" />
        </div>
        <div class="form-row">
          <input type="tel" placeholder="WhatsApp / Phone Number" class="form-input" />
          <select class="form-input form-select">
            <option value="" disabled selected>What's brought you here today?</option>
            {% for opt in cta.form_options %}
            <option>{{ opt }}</option>
            {% endfor %}
          </select>
        </div>
        <button type="submit" class="btn btn-primary btn-lg btn-full">{{ cta.button_text }}</button>
        <p class="form-disclaimer">{{ cta.disclaimer }}</p>
      </form>
      <div class="form-success" id="formSuccess" style="display:none;">
        <div class="success-icon">✓</div>
        <h3>{{ cta.success_heading }}</h3>
        <p>{{ cta.success_body }}</p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq">
    <div class="container">
      <div class="section-header">
        <div class="section-tag">Questions</div>
        <h2>Things People Often Ask</h2>
      </div>
      <div class="faq-list">
        {% for item in faqs.questions %}
        <div class="faq-item">
          <button class="faq-question" onclick="toggleFaq(this)">
            {{ item.question }}
            <span class="faq-arrow">▼</span>
          </button>
          <div class="faq-answer">
            <p>{{ item.answer }}</p>
          </div>
        </div>
        {% endfor %}
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="container footer-inner">
      <div class="footer-brand">
        <a href="#" class="logo">
          <img src="logo.png?v=2" alt="Healthspan Concierge — Live Better. For Longer." class="logo-img" style="height:48px!important;max-height:48px!important;width:auto!important;margin-left:36px;" />
        </a>
        <p class="footer-tagline">Longevity Concierge for Adults 50+ Across Asia</p>
        <div class="footer-social">
          <a href="#" aria-label="LinkedIn">in</a>
          <a href="#" aria-label="Instagram">ig</a>
          <a href="#" aria-label="WhatsApp">wa</a>
        </div>
      </div>
      <div class="footer-links">
        <div class="footer-col">
          <h4>Our Approach</h4>
          <a href="#services">Strength & Conditioning</a>
          <a href="#services">Nutrition</a>
          <a href="#services">Sleep</a>
          <a href="#services">Mobility</a>
          <a href="#services">State of Mind</a>
          <a href="#services">Medical Coordination</a>
        </div>
        <div class="footer-col">
          <h4>Learn</h4>
          <a href="#what-is-healthspan">What is Healthspan?</a>
          <a href="#what-affects">What Affects Healthspan?</a>
          <a href="#glossary">Plain Language Glossary</a>
          <a href="#personalisation">How We Personalise</a>
        </div>
        <div class="footer-col">
          <h4>Locations</h4>
          <span>Singapore</span>
          <span>Hong Kong</span>
          <span>Tokyo</span>
          <span>Bangkok</span>
          <span>Kuala Lumpur</span>
          <span>+ 3 more cities</span>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <div class="container">
        <p>&copy; 2026 Healthspan.Asia. All rights reserved.</p>
        <div class="footer-legal">
          <a href="#">Privacy Policy</a>
          <a href="#">Terms of Service</a>
        </div>
      </div>
    </div>
  </footer>

  <script src="script.js"></script>
  <script>
    if (window.netlifyIdentity) {
      window.netlifyIdentity.on("init", user => {
        if (!user) {
          window.netlifyIdentity.on("login", () => { document.location.href = "/admin/"; });
        }
      });
    }
  </script>
</body>
</html>
